# Production template. For local Excel-only work use NODE_ENV=development
# and AUTH_DISABLED=true instead.
# Runtime database account. Give this account data access only; no DDL.
NODE_ENV=production
DATABASE_URL=postgresql://gp1_runtime:CHANGE_ME@host:5432/postgres

# Migration account used only by ensureSchema at startup.
MIGRATION_DATABASE_URL=postgresql://gp1_migrator:CHANGE_ME@host:5432/postgres
DATABASE_SSL=true
# Paste the provider CA certificate with newlines encoded as \n when required.
DATABASE_CA_CERT=
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=20000

# Supabase Auth. The anon key is public by design; the service-role key is server-only.
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME
ADMIN_EMAIL=gp1.dailyreport@gmail.com
AUTH_REDIRECT_URL=https://rdf2-downtime.onrender.com/accept-invite.html

# Raspberry Pi Grab Crane device sync. Generate at least 32 random characters
# and configure the same value only in Render and /etc/gp1-grab-sync.ini.
GRAB_SYNC_DEVICE_ID=grab-pi-1
GRAB_SYNC_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_TOKEN

# Private Supabase Storage bucket used by the scheduled backup command.
BACKUP_BUCKET=gp1-backups
BACKUP_RETENTION_DAYS=35

# Local Excel development may disable Auth. Never set this in Production.
# AUTH_DISABLED=true
